<div class="product-show">
  <h1>Your Cart</h1>

  <% if @cart_items.empty? %>
    <p>Your cart is empty. <%= link_to "Browse products", products_path %></p>
  <% else %>
    <table class="cart-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Subtotal</th>
          <th>Remove</th>
        </tr>
      </thead>
      <tbody>
        <% @cart_items.each do |item| %>
          <tr>
            <td><%= link_to item[:product].name, product_path(item[:product]) %></td>
            <td><%= number_to_currency(item[:product].current_price&.amount) %></td>
            <td>
              <%= form_with url: update_cart_path(item[:product].id), method: :patch do |f| %>
                <%= f.number_field :quantity, value: item[:quantity], min: 1, max: 99, class: "qty-input" %>
                <%= f.submit "Update", class: "btn-small" %>
              <% end %>
            </td>
            <td><%= number_to_currency(item[:subtotal]) %></td>
            <td>
              <%= button_to "Remove", remove_from_cart_path(item[:product].id), method: :delete, class: "btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="cart-total">
      <strong>Total: <%= number_to_currency(@total) %></strong>
    </div>

    <%= link_to "Continue Shopping", products_path, class: "btn-secondary" %>
  <% end %>
</div>