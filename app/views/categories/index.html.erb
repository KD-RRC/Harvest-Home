<div class="products-header">
  <h1>Shop by Category</h1>
  <p>Browse our Manitoba producers by product type.</p>
</div>

<div class="categories-grid">
  <% @categories.each do |category| %>
    <div class="category-card">
      <h2><%= link_to category.name, category_path(category) %></h2>
      <p><%= category.description %></p>
      <p class="category-count"><%= category.products.count %> products</p>
      <%= link_to "Browse #{category.name}", category_path(category), class: "btn-primary" %>
    </div>
  <% end %>
</div>