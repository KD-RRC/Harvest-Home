<div class="auth-container">
  <h2>Sign In</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <% if alert %>
      <div class="auth-errors">
        <p><%= alert %></p>
      </div>
    <% end %>

    <div class="form-section">
      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, class: "form-input" %>
      </div>
      <div class="form-group" style="display:flex; align-items:center; gap:0.5rem;">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, style: "margin:0; font-family:Arial,sans-serif;" %>
      </div>
      <%= f.submit "Sign In", class: "btn-primary" %>
    </div>
  <% end %>

  <p class="auth-link"><%= link_to "Don't have an account? Sign up", new_user_registration_path %></p>
  <p class="auth-link"><%= link_to "Forgot your password?", new_user_password_path %></p>
</div>